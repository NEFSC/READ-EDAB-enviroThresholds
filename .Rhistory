# Save
file_name <- file.path(
out_dir,
paste0(gsub(" ", "_", species_name), "_", year, "_suitable.png")
)
ggsave(file_name, plot = p, width = 7, height = 6, dpi = 300)
# Clean memory
rm(bt, bt_mean, suitable)
gc()
}
